[flake8]
max-line-length = 100
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    build,
    dist,
    *.egg-info,
    .venv,
    venv

[isort]
profile = black
line_length = 100
skip_gitignore = true

[pytest]
testpaths = tests
python_files = test_*.py
python_classes = Test*
python_functions = test_*
addopts = -v --tb=short --cov=ai_project --cov-report=term-missing --cov-report=html
